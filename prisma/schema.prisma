generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  scans         Scan[]
}

model Scan {
  id          String   @id @default(cuid())
  url         String
  status      String   // SAFE, SUSPICIOUS, MALICIOUS, ERROR
  riskScore   Int
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  details     String   // JSON string with API breakdown
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
